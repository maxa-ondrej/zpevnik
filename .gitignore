# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.python-version
.uv/

# Node / Expo
node_modules/
.expo/
.expo-shared/
dist/
web-build/
*.log
.metro-health-check*

# iOS / Android build artifacts
ios/build/
ios/Pods/
ios/*.xcworkspace/xcuserdata/
android/build/
android/app/build/
android/.gradle/
*.keystore

# Editor
.vscode/
.idea/
.DS_Store

# Claude Code per-user settings (not for the team)
.claude/settings.local.json

# Pipeline working files
pipeline/.cache/
pipeline/.work/
*.tmp

# Local source PDFs — too large + may be unredistributable derivatives
input/
*.pdf
!docs/**/*.pdf

# Pipeline intermediates dropped into songs/ alongside per-song dirs.
# (Per-song dirs and songs/index.json stay eligible for tracking.)
/songs/_*.json

# OS
Thumbs.db
